{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-Werror",
                "-Wshadow",
                "-Wconversion",
                "-std=c99",
                "-O0",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}/build/debug/${fileBasenameNoExtension}"
            ],
            "windows": {
                "args": [
                    "-Wall",
                    "-Wextra",
                    "-Wpedantic",
                    "-Werror",
                    "-Wshadow",
                    "-Wconversion",
                    "-std=c99",
                    "-O0",
                    "-g",
                    "${file}",
                    "-o",
                    "${workspaceFolder}/build/debug/${fileBasenameNoExtension}.exe"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-Werror",
                "-Wshadow",
                "-Wconversion",
                "-std=c99",
                "-O2",
                "-DNDEBUG",
                "${file}",
                "-o",
                "${workspaceFolder}/build/release/${fileBasenameNoExtension}"
            ],
            "windows": {
                "args": [
                    "-Wall",
                    "-Wextra",
                    "-Wpedantic",
                    "-Werror",
                    "-Wshadow",
                    "-Wconversion",
                    "-std=c99",
                    "-O2",
                    "-DNDEBUG",
                    "${file}",
                    "-o",
                    "${workspaceFolder}/build/release/${fileBasenameNoExtension}.exe"
                ]
            },
            "problemMatcher": "$gcc"
        }
    ]
}
