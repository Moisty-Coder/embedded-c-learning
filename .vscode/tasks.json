{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Debug Program",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-Werror",
                "-Wshadow",
                "-Wconversion",
                "-std=c99",
                "-O0",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}/build/${fileBasenameNoExtension}"
            ],
            "windows": {
                "args": [
                    "-Wall", // enable common warnings
                    "-Wextra", // enable common warnings
                    "-Wpedantic",
                    "-Werror",
                    "-Wshadow", // catch variable shadowing (same variable names)
                    "-Wconversion", // detect implicit narrowing conversion.
                    "-std=c99",
                    "-O0", // easier debugging
                    "-g", // generate debug symbols
                    "${file}",
                    "-o",
                    "${workspaceFolder}/build/${fileBasenameNoExtension}.exe"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}
